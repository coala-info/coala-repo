cwlVersion: v1.2
class: CommandLineTool
baseCommand: iu-gen-configs
label: illumina-utils_iu-gen-configs
doc: "Generate config files for demultiplexed FASTQ files\n\nTool homepage: https://github.com/meren/illumina-utils"
inputs:
  - id: file
    type: File
    doc: TAB-delimited file to describe where samples are. The header line 
      should be "sample", "r1", and "r2". Each row should list the sample name 
      in the first column, and full path for r1 and r2. This output is 
      automatically generated by the iu-demultiplex script.
    inputBinding:
      position: 1
  - id: e_mail
    type:
      - 'null'
      - string
    doc: E-mail address (currently is not used for anything)
    inputBinding:
      position: 102
      prefix: --e-mail
  - id: r1_prefix
    type:
      - 'null'
      - string
    doc: Prefix for Read 1 to be put in every config file.
    inputBinding:
      position: 102
      prefix: --r1-prefix
  - id: r2_prefix
    type:
      - 'null'
      - string
    doc: Prefix for Read 2.
    inputBinding:
      position: 102
      prefix: --r2-prefix
outputs:
  - id: output_dir
    type:
      - 'null'
      - Directory
    doc: Directory for output storage. INI files will also be generated in this 
      directory.
    outputBinding:
      glob: $(inputs.output_dir)
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/illumina-utils:2.13--pyhdfd78af_0
