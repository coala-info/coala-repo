cwlVersion: v1.2
class: CommandLineTool
baseCommand: python GetUTRSequences
label: ribominer_GetUTRSequences
doc: "Get UTR sequences from transcript and coordinate files.\n\nTool homepage: https://github.com/xryanglab/RiboMiner"
inputs:
  - id: coordinate_file
    type: File
    doc: The file should contain the coordinate of start and stop codon. 
      Generated by RiboCode.
    inputBinding:
      position: 101
      prefix: --coordinateFile
  - id: output_prefix
    type: string
    doc: Prefix of output files.
    inputBinding:
      position: 101
      prefix: --otput_prefix
  - id: transcript_file
    type:
      - 'null'
      - File
    doc: Input file(s) in fasta format. All transcript sequences are from the 
      longest transcripts of protein coding genes which may be generated by 
      GetProteinCodingSequence.py
    inputBinding:
      position: 101
      prefix: --input
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/ribominer:0.2.3.2--pyh5e36f6f_0
stdout: ribominer_GetUTRSequences.out
