cwlVersion: v1.2
class: CommandLineTool
baseCommand: disco
label: concoord_disco
doc: "disco generates (macro)molecular structures based on a set of geometric constraints
  (usually generated by the program \"dist\", but also additional restraints may be
  specified).\n\nTool homepage: https://www3.mpibpc.mpg.de/groups/de_groot/concoord"
inputs:
  - id: additional_restraints
    type:
      - 'null'
      - File
    doc: file containing additional distance restraints.
    inputBinding:
      position: 101
      prefix: -r
  - id: bound_smoothing
    type:
      - 'null'
      - int
    doc: number of rounds of triangular bound smoothing (if >= 6, tetragonal BS is
      activated)
    default: 0
    inputBinding:
      position: 101
      prefix: -bs
  - id: bump_check
    type:
      - 'null'
      - boolean
    doc: do extra bump check.
    inputBinding:
      position: 101
      prefix: -bump
  - id: chirality_check
    type:
      - 'null'
      - int
    doc: 'chirality check. 0 : no chirality checks; 1: only check afterwards 2: check
      on the fly'
    default: 2
    inputBinding:
      position: 101
      prefix: -c
  - id: convergence_limit
    type:
      - 'null'
      - int
    doc: consider convergence failed after n non-productive iterations.
    default: 500
    inputBinding:
      position: 101
      prefix: -con
  - id: cutoff_radius
    type:
      - 'null'
      - float
    doc: cut-off radius for pairlist (only valid together with -bump)
    default: 0.5
    inputBinding:
      position: 101
      prefix: -rc
  - id: damping_factor
    type:
      - 'null'
      - float
    doc: damping factor for distance corrections.
    default: 1.0
    inputBinding:
      position: 101
      prefix: -damp
  - id: dynamic_tolerances
    type:
      - 'null'
      - int
    doc: nr of rounds to dynamically set tolerances.
    default: 0
    inputBinding:
      position: 101
      prefix: -dyn
  - id: input_distances
    type:
      - 'null'
      - File
    doc: file containing input distances. This file is usually the output of the program
      dist.
    default: dist.dat
    inputBinding:
      position: 101
      prefix: -d
  - id: input_structure
    type:
      - 'null'
      - File
    doc: file containing input structure in PDB file format. This file is usually
      the output of the program dist.
    default: dist.pdb
    inputBinding:
      position: 101
      prefix: -p
  - id: max_iterations
    type:
      - 'null'
      - int
    doc: maximum nr. of iterations per structure.
    default: 2500
    inputBinding:
      position: 101
      prefix: -i
  - id: max_trials
    type:
      - 'null'
      - int
    doc: maximum nr. of trials per run.
    default: 25
    inputBinding:
      position: 101
      prefix: -t
  - id: max_violations
    type:
      - 'null'
      - float
    doc: maximal acceptable sum of violations (in nm)
    default: 1.0
    inputBinding:
      position: 101
      prefix: -viol
  - id: no_fit
    type:
      - 'null'
      - boolean
    doc: do not fit generated structures to reference
    inputBinding:
      position: 101
      prefix: -f
  - id: num_structures
    type:
      - 'null'
      - int
    doc: nr. of structures to be generated.
    default: 500
    inputBinding:
      position: 101
      prefix: -n
  - id: pairlist_frequency
    type:
      - 'null'
      - int
    doc: pairlist update frequency (only valid together with -bump)
    default: 10
    inputBinding:
      position: 101
      prefix: -l
  - id: random_seed
    type:
      - 'null'
      - int
    doc: initial random seed
    default: 741265
    inputBinding:
      position: 101
      prefix: -s
  - id: scale_factor
    type:
      - 'null'
      - float
    doc: pre-scale coordinates with this factor.
    default: 1.0
    inputBinding:
      position: 101
      prefix: -is
  - id: use_input_coords
    type:
      - 'null'
      - boolean
    doc: use input coordinates instead of random starting coordinates
    inputBinding:
      position: 101
      prefix: -ref
  - id: verbose
    type:
      - 'null'
      - boolean
    doc: be verbose
    inputBinding:
      position: 101
      prefix: -v
outputs:
  - id: output_pdb_prefix
    type:
      - 'null'
      - File
    doc: basic filename for output PDB structures. (a number plus extension .pdb will
      be added)
    outputBinding:
      glob: $(inputs.output_pdb_prefix)
  - id: output_nmr_pdb
    type:
      - 'null'
      - File
    doc: output trajectory in NMR-PDB format
    outputBinding:
      glob: $(inputs.output_nmr_pdb)
  - id: output_xtc
    type:
      - 'null'
      - File
    doc: output trajectory in xtc format
    outputBinding:
      glob: $(inputs.output_xtc)
  - id: output_gromos
    type:
      - 'null'
      - File
    doc: output trajectory in formatted GROMOS87 format
    outputBinding:
      glob: $(inputs.output_gromos)
  - id: output_rmsd
    type:
      - 'null'
      - File
    doc: file with RMSD values of output structures to initial structure.
    outputBinding:
      glob: $(inputs.output_rmsd)
  - id: output_b_factors
    type:
      - 'null'
      - File
    doc: file with mean square atomic fluctuations expressed as B-factors
    outputBinding:
      glob: $(inputs.output_b_factors)
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/concoord:2.1.2--h9ee0642_4
