cwlVersion: v1.2
class: CommandLineTool
baseCommand:
  - psass
  - analyze
label: psass_analyze
doc: "Analyze sliding window metrics and sex-biased SNPs from sync files\n\nTool homepage:
  https://github.com/RomainFeron/PSASS"
inputs:
  - id: input_file
    type: File
    doc: Path to a sync file generated by psass pileup or popoolation2
    inputBinding:
      position: 1
  - id: freq_het
    type:
      - 'null'
      - float
    doc: Frequency of a sex-linked SNP in the heterogametic sex
    inputBinding:
      position: 102
      prefix: --freq-het
  - id: freq_hom
    type:
      - 'null'
      - float
    doc: Frequency of a sex-linked SNP in the homogametic sex
    inputBinding:
      position: 102
      prefix: --freq-hom
  - id: gff_file
    type:
      - 'null'
      - File
    doc: Path to a GFF file for gene-specific output
    inputBinding:
      position: 102
      prefix: --gff-file
  - id: group_snps
    type:
      - 'null'
      - boolean
    doc: If set, group consecutive snps to count them as a single polymorphism
    inputBinding:
      position: 102
      prefix: --group-snps
  - id: min_depth
    type:
      - 'null'
      - int
    doc: Minimum depth to include a site in the analyses
    inputBinding:
      position: 102
      prefix: --min-depth
  - id: min_fst
    type:
      - 'null'
      - float
    doc: Minimum FST to output a site in the FST positions file
    inputBinding:
      position: 102
      prefix: --min-fst
  - id: output_resolution
    type:
      - 'null'
      - int
    doc: Output resolution for sliding window metrics (in bp)
    inputBinding:
      position: 102
      prefix: --output-resolution
  - id: pool1
    type:
      - 'null'
      - string
    doc: Name of the first pool (order in the pileup file)
    inputBinding:
      position: 102
      prefix: --pool1
  - id: pool2
    type:
      - 'null'
      - string
    doc: Name of the second pool (order in the pileup file)
    inputBinding:
      position: 102
      prefix: --pool2
  - id: popoolation
    type:
      - 'null'
      - boolean
    doc: If set, assumes the input file was generated with popoolation2
    inputBinding:
      position: 102
      prefix: --popoolation
  - id: range_het
    type:
      - 'null'
      - float
    doc: Range of frequency for a sex-linked SNP in the heterogametic sex
    inputBinding:
      position: 102
      prefix: --range-het
  - id: range_hom
    type:
      - 'null'
      - float
    doc: Range of frequency for a sex-linked SNP in the homogametic sex
    inputBinding:
      position: 102
      prefix: --range-hom
  - id: window_size
    type:
      - 'null'
      - int
    doc: Size of the sliding window (in bp)
    inputBinding:
      position: 102
      prefix: --window-size
outputs:
  - id: output_file
    type: File
    doc: Path to an output file for sliding window metrics
    outputBinding:
      glob: '*.out'
  - id: snp_file
    type:
      - 'null'
      - File
    doc: Output sex-biased SNPs to this file
    outputBinding:
      glob: $(inputs.snp_file)
  - id: fst_file
    type:
      - 'null'
      - File
    doc: Output high FST positions to this file
    outputBinding:
      glob: $(inputs.fst_file)
  - id: genes_file
    type:
      - 'null'
      - File
    doc: Output gene metrics to this file (requires a GFF file)
    outputBinding:
      glob: $(inputs.genes_file)
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/psass:3.1.0--hf5e1c6e_4
