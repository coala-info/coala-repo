cwlVersion: v1.2
class: CommandLineTool
baseCommand: glistquery
label: genometester_glistquery
doc: "Query a list file generated by glistmaker.\n\nTool homepage: https://github.com/bioinfo-ut/GenomeTester4"
inputs:
  - id: input_list
    type: File
    doc: The list file to query.
    inputBinding:
      position: 1
  - id: debug_level
    type:
      - 'null'
      - boolean
    doc: increase debug level
    inputBinding:
      position: 102
      prefix: -D
  - id: distribution_max
    type:
      - 'null'
      - int
    doc: print distribution up to MAX
    inputBinding:
      position: 102
      prefix: -distribution
  - id: list_file
    type:
      - 'null'
      - File
    doc: list file made by glistmaker
    inputBinding:
      position: 102
      prefix: --listfile
  - id: max_frequency
    type:
      - 'null'
      - int
    doc: maximum frequency of the printed words
    inputBinding:
      position: 102
      prefix: --maxfreq
  - id: min_frequency
    type:
      - 'null'
      - int
    doc: minimum frequency of the printed words
    inputBinding:
      position: 102
      prefix: --minfreq
  - id: mismatch_number
    type:
      - 'null'
      - int
    doc: specify number of mismatches
    inputBinding:
      position: 102
      prefix: --mismatch
  - id: perfect_match_number
    type:
      - 'null'
      - int
    doc: specify number of 3' perfect matches
    inputBinding:
      position: 102
      prefix: --perfectmatch
  - id: print_all_mismatches
    type:
      - 'null'
      - boolean
    doc: in case of mismatches prints all found words
    inputBinding:
      position: 102
      prefix: -all
  - id: print_gc
    type:
      - 'null'
      - boolean
    doc: print average GC content of all words
    inputBinding:
      position: 102
      prefix: -gc
  - id: print_median
    type:
      - 'null'
      - boolean
    doc: print min/max/median/average and exit
    inputBinding:
      position: 102
      prefix: -median
  - id: print_statistics
    type:
      - 'null'
      - boolean
    doc: print statistics of the list file and exit
    inputBinding:
      position: 102
      prefix: -stat
  - id: query
    type:
      - 'null'
      - string
    doc: single query word
    inputBinding:
      position: 102
      prefix: --query
  - id: query_file
    type:
      - 'null'
      - File
    doc: list of query words in a file
    inputBinding:
      position: 102
      prefix: --queryfile
  - id: seq_file
    type:
      - 'null'
      - File
    doc: FastA/FastQ file
    inputBinding:
      position: 102
      prefix: --seqfile
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: biocontainers/genometester:v4.0git20180508.a9c14a6dfsg-1-deb_cv1
stdout: genometester_glistquery.out
