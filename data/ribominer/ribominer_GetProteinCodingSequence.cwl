cwlVersion: v1.2
class: CommandLineTool
baseCommand: python GetProteinCodingSequence
label: ribominer_GetProteinCodingSequence
doc: "Extracts protein-coding sequences based on specified coordinates.\n\nTool homepage:
  https://github.com/xryanglab/RiboMiner"
inputs:
  - id: coordinate_file
    type: File
    doc: The file should contain the coordinate of start and stop codon. 
      Generated by OutputTranscriptInfo.py.
    inputBinding:
      position: 101
      prefix: --coordinateFile
  - id: genetic_code
    type:
      - 'null'
      - string
    doc: 'Which genetic code to use. default is the standard code. table = 1, is the
      standard table, ref: https://www.ncbi.nlm.nih.gov/Taxonomy/Utils/wprintgc.cgi'
    inputBinding:
      position: 101
      prefix: --table
  - id: id_type
    type:
      - 'null'
      - string
    doc: define the id type users input. the default is transcript id, if not, 
      will be transformed into transcript id.
    inputBinding:
      position: 101
      prefix: --id-type
  - id: left_position
    type: int
    doc: The left position (codon level) of the sequence you wanna to extract.
    inputBinding:
      position: 101
      prefix: --left_coor
  - id: mode
    type:
      - 'null'
      - string
    doc: Mode for sequence extraction.
    inputBinding:
      position: 101
      prefix: --mode
  - id: output_prefix
    type: string
    doc: Prefix of output files.
    inputBinding:
      position: 101
      prefix: --otput_prefix
  - id: right_position
    type: int
    doc: The right position (codon level) of the sequence you wanna to extract
    inputBinding:
      position: 101
      prefix: --right_coor
  - id: select_trans_list
    type:
      - 'null'
      - File
    doc: Selected transcript list used for metagene analysis. This files 
      requires the first column must be the transcript ID with a column name.
    inputBinding:
      position: 101
      prefix: --select_trans_list
  - id: transcript_file
    type:
      - 'null'
      - File
    doc: Input file(s) in fasta format. generated by RiboCode
    inputBinding:
      position: 101
      prefix: --input
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/ribominer:0.2.3.2--pyh5e36f6f_0
stdout: ribominer_GetProteinCodingSequence.out
