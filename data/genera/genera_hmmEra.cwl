cwlVersion: v1.2
class: CommandLineTool
baseCommand: hmmEra
label: genera_hmmEra
doc: "HMMER-based gene family analysis tool\n\nTool homepage: https://github.com/josuebarrera/GenEra"
inputs:
  - id: ages_file
    type:
      - 'null'
      - File
    doc: Gene age table previously generated by GenEra
    inputBinding:
      position: 101
      prefix: --ages
  - id: eval
    type:
      - 'null'
      - float
    doc: E-value threshold to retain homologs against the Uniprot database
    inputBinding:
      position: 101
      prefix: --eval
  - id: fasta_file
    type:
      - 'null'
      - File
    doc: Name of input FASTA file
    inputBinding:
      position: 101
      prefix: --fasta
  - id: strata
    type:
      - 'null'
      - int
    doc: Genes equal and younger to this phylostratum will be assessed with 
      jackhmmer
    inputBinding:
      position: 101
      prefix: --strata
outputs:
  - id: output_file
    type:
      - 'null'
      - File
    doc: Output file name
    outputBinding:
      glob: $(inputs.output_file)
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/genera:1.4.2--py38hdfd78af_0
