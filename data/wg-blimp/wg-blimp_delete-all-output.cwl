cwlVersion: v1.2
class: CommandLineTool
baseCommand:
  - wg-blimp
  - delete-all-output
label: wg-blimp_delete-all-output
doc: "Remove all files generated by the pipeline. This includes reference genome\n\
  \  indices, as well. Use with care!\n\nTool homepage: https://github.com/MarWoes/wg-blimp"
inputs:
  - id: config_yaml
    type: File
    doc: Path to the pipeline configuration YAML file.
    inputBinding:
      position: 1
  - id: dry_run
    type:
      - 'null'
      - boolean
    doc: Only dry-run deleting the pipeline output.
    inputBinding:
      position: 102
      prefix: --dry-run
  - id: yes
    type:
      - 'null'
      - boolean
    doc: Confirm the action without prompting.
    inputBinding:
      position: 102
      prefix: --yes
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/wg-blimp:0.10.0--pyh5e36f6f_0
stdout: wg-blimp_delete-all-output.out
