cwlVersion: v1.2
class: CommandLineTool
baseCommand:
  - dysgu
  - filter
label: dysgu_filter
doc: "Filter a vcf generated by dysgu. Unique SVs can be found in the input_vcf by
  supplying a --normal-vcf (single or multi-sample), and normal bam files. Bam/vcf
  samples with the same name as the input_vcf will be ignored\n\nTool homepage: https://github.com/kcleal/dysgu"
inputs:
  - id: input_vcf
    type: File
    doc: Input VCF file
    inputBinding:
      position: 1
  - id: normal_bams
    type:
      - 'null'
      - type: array
        items: File
    doc: Normal BAM files
    inputBinding:
      position: 2
  - id: ignore_read_groups
    type:
      - 'null'
      - boolean
    doc: Ignore ReadGroup RG tags when parsing sample names. Filenames will be 
      used instead
    inputBinding:
      position: 103
      prefix: --ignore-read-groups
  - id: interval_size
    type:
      - 'null'
      - int
    doc: Interval size for searching normal-vcf/normal-bams
    inputBinding:
      position: 103
      prefix: --interval-size
  - id: keep_all
    type:
      - 'null'
      - boolean
    doc: All SVs classified as normal will be kept in the output, labelled as 
      filter=normal
    inputBinding:
      position: 103
      prefix: --keep-all
  - id: max_divergence
    type:
      - 'null'
      - float
    doc: Remove SV if normal_bam displays divergence > max-divergence at same 
      location
    inputBinding:
      position: 103
      prefix: --max-divergence
  - id: min_mapq
    type:
      - 'null'
      - float
    doc: Remove SV with mean mapqq < min-mapq
    inputBinding:
      position: 103
      prefix: --min-mapq
  - id: min_prob
    type:
      - 'null'
      - float
    doc: Remove SV with PROB value < min-prob
    inputBinding:
      position: 103
      prefix: --min-prob
  - id: normal_vcf
    type:
      - 'null'
      - File
    doc: Vcf file for normal sample, or panel of normals. The SM tag of input 
      bams is used to ignore the input_vcf for multi-sample vcfs
    inputBinding:
      position: 103
      prefix: --normal-vcf
  - id: pass_prob
    type:
      - 'null'
      - float
    doc: Re-label SV as PASS if PROB value >= pass-prob
    inputBinding:
      position: 103
      prefix: --pass-prob
  - id: procs
    type:
      - 'null'
      - int
    doc: Reading threads for normal_bams
    inputBinding:
      position: 103
      prefix: --procs
  - id: random_bam_sample
    type:
      - 'null'
      - int
    doc: Choose N random normal-bams to search. Use -1 to ignore
    inputBinding:
      position: 103
      prefix: --random-bam-sample
  - id: reference
    type:
      - 'null'
      - File
    doc: Reference for cram input files
    inputBinding:
      position: 103
      prefix: --reference
  - id: support_fraction
    type:
      - 'null'
      - float
    doc: Minimum threshold support fraction / coverage (SU/COV)
    inputBinding:
      position: 103
      prefix: --support-fraction
  - id: target_sample
    type:
      - 'null'
      - string
    doc: If input_vcf if multi-sample, use target-sample as input
    inputBinding:
      position: 103
      prefix: --target-sample
outputs:
  - id: svs_out
    type:
      - 'null'
      - File
    doc: Output file
    outputBinding:
      glob: $(inputs.svs_out)
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/dysgu:1.8.7--py311h8ddd9a4_0
