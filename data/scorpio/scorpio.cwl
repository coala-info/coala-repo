cwlVersion: v1.2
class: CommandLineTool
baseCommand: scorpio
label: scorpio
doc: "A tool for classifying SARS-CoV-2 haplotypes using constellations (haplotype
  definitions).\n\nTool homepage: https://github.com/cov-lineages/scorpio"
inputs:
  - id: clobber
    type:
      - 'null'
      - boolean
    doc: Overwrite output files if they already exist.
    inputBinding:
      position: 101
      prefix: --clobber
  - id: constellations
    type:
      - 'null'
      - Directory
    doc: Directory containing constellation (haplotype) definitions.
    inputBinding:
      position: 101
      prefix: --constellations
  - id: fasta
    type: File
    doc: Input FASTA file containing sequences to be classified.
    inputBinding:
      position: 101
      prefix: --fasta
  - id: min_multi_lineage_group_size
    type:
      - 'null'
      - int
    doc: Minimum number of sequences required to define a multi-lineage group.
    inputBinding:
      position: 101
      prefix: --min-multi-lineage-group-size
  - id: mutations
    type:
      - 'null'
      - File
    doc: A CSV file containing the mutations for each sequence (optional, can be
      generated by scorpio).
    inputBinding:
      position: 101
      prefix: --mutations
  - id: threads
    type:
      - 'null'
      - int
    doc: Number of threads to use for processing.
    inputBinding:
      position: 101
      prefix: --threads
outputs:
  - id: out_csv
    type:
      - 'null'
      - File
    doc: Output CSV file containing the classification results.
    outputBinding:
      glob: $(inputs.out_csv)
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/scorpio:0.3.19--pyhdfd78af_0
