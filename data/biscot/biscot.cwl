cwlVersion: v1.2
class: CommandLineTool
baseCommand: py
label: biscot
doc: "Reorganizes scaffolds generated by the Bionano scaffolding tool to remove small
  gaps that are unnecessary\n\nTool homepage: https://github.com/institut-de-genomique/biscot"
inputs:
  - id: aggressive
    type:
      - 'null'
      - boolean
    doc: Enables Blat phase
    inputBinding:
      position: 101
      prefix: --aggressive
  - id: cmap_1_path
    type: File
    doc: "Path to a query CMAP file (example : 'E_CTTAAG_Q_NGScontigs_A_HYBRID_q.cmap')"
    inputBinding:
      position: 101
      prefix: --cmap-1
  - id: cmap_2_path
    type:
      - 'null'
      - File
    doc: "Path to a query cmap (example : 'E_GCTCTTC_Q_NGScontigs_A_HYBRID_q.cmap')"
    inputBinding:
      position: 101
      prefix: --cmap-2
  - id: cmap_ref_path
    type: File
    doc: "Path to the reference CMAP file (example : '...NGS_contigs_HYBRID_Export_r.cmap')"
    inputBinding:
      position: 101
      prefix: --cmap-ref
  - id: contigs_path
    type: File
    doc: Path to the contigs file that was scaffolded by the Bionano Access
    inputBinding:
      position: 101
      prefix: --contigs
  - id: debug
    type:
      - 'null'
      - boolean
    doc: Activates debug level logs
    inputBinding:
      position: 101
      prefix: --debug
  - id: key_path
    type: File
    doc: Path to the Bionano 'key' file giving the correspondance between maps 
      and contigs
    inputBinding:
      position: 101
      prefix: --key
  - id: only_confirmed_pos
    type:
      - 'null'
      - boolean
    doc: To be retained, an alignment position in --xmap-1 or --xmap-2 has to be
      present in --xmap-2enz
    inputBinding:
      position: 101
      prefix: --only-confirmed-pos
  - id: xmap_1_path
    type: File
    doc: Path to a XMAP file
    inputBinding:
      position: 101
      prefix: --xmap-1
  - id: xmap_2_path
    type:
      - 'null'
      - File
    doc: "Path to a query xmap (example : 'E_GCTCTTC_Q_NGScontigs_A_HYBRID.xmap')"
    inputBinding:
      position: 101
      prefix: --xmap-2
  - id: xmap_2enz
    type:
      - 'null'
      - File
    doc: Path to a xmap file containing mappings for both enzymes
    inputBinding:
      position: 101
      prefix: --xmap-2enz
outputs:
  - id: output_directory
    type:
      - 'null'
      - Directory
    doc: Name of the output directory
    outputBinding:
      glob: $(inputs.output_directory)
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/biscot:2.3.3--pyh7cba7a3_0
