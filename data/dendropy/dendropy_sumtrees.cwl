cwlVersion: v1.2
class: CommandLineTool
baseCommand: sumtrees
label: dendropy_sumtrees
doc: "SumTrees is a program to summarize non-rooting phylogenetic trees, such as those
  generated by Bayesian MCMC or bootstrap analyses.\n\nTool homepage: https://github.com/jeetsukumaran/DendroPy"
inputs: []
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/dendropy:5.0.8--pyhdfd78af_1
stdout: dendropy_sumtrees.out
