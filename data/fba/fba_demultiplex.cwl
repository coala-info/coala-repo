cwlVersion: v1.2
class: CommandLineTool
baseCommand: fba_demultiplex
label: fba_demultiplex
doc: "Demultiplex cells based on the abundance of features (matrix generated by `count`
  as input).\n\nTool homepage: https://github.com/jlduan/fba"
inputs:
  - id: clustering_method
    type:
      - 'null'
      - string
    doc: specify initial clustering method for demultiplexing method 1.
    inputBinding:
      position: 101
      prefix: --clustering_method
  - id: demultiplexing_method
    type:
      - 'null'
      - string
    doc: "specify demultiplexing method. '1': Stoeckius et al. 2018."
    inputBinding:
      position: 101
      prefix: -dm
  - id: input
    type: File
    doc: specify an input file (feature count matrix). The output of `count`
    inputBinding:
      position: 101
      prefix: --input
  - id: normalization_method
    type:
      - 'null'
      - string
    doc: "specify normalization method. 'clr': centred log-ratio transformation. 'log':
      log10 transformation."
    inputBinding:
      position: 101
      prefix: -nm
  - id: num_cells
    type:
      - 'null'
      - int
    doc: specify minimal number of positive cells required for a feature to be 
      included for demultiplexing.
    inputBinding:
      position: 101
      prefix: --num_cells
  - id: output_directory
    type:
      - 'null'
      - Directory
    doc: specify a output directory.
    inputBinding:
      position: 101
      prefix: --output_directory
  - id: quantile
    type:
      - 'null'
      - float
    doc: specify quantile cutoff for the probability mass function for 
      demultiplexing method 1.
    inputBinding:
      position: 101
      prefix: --quantile
  - id: visualization
    type:
      - 'null'
      - boolean
    doc: specify to visualize demultiplexing result
    inputBinding:
      position: 101
      prefix: --visualization
  - id: visualization_method
    type:
      - 'null'
      - string
    doc: specify embedding method for visualization (works if '-v' is given).
    inputBinding:
      position: 101
      prefix: --visualization_method
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/fba:0.0.13--pyhdfd78af_0
stdout: fba_demultiplex.out
