cwlVersion: v1.2
class: CommandLineTool
baseCommand: get_homologues_parse_pangenome_matrix.pl
label: get_homologues_parse_pangenome_matrix.pl
doc: "Parses the pangenome matrix generated by compare_clusters.pl to report cluster
  types and perform various analyses.\n\nTool homepage: https://github.com/eead-csic-compbio/get_homologues"
inputs:
  - id: absent_in_b
    type:
      - 'null'
      - boolean
    doc: find genes/clusters which are absent in B (optional, requires -B)
    inputBinding:
      position: 101
      prefix: -a
  - id: gene_family_expansions
    type:
      - 'null'
      - boolean
    doc: find gene family expansions in A with respect to B (optional, requires 
      -A & -B)
    inputBinding:
      position: 101
      prefix: -e
  - id: group_a_taxa_file
    type:
      - 'null'
      - File
    doc: file with taxon names (.faa,.gbk,.nucl files) of group A (optional, 
      example -A clade_list_pathogenic.txt)
    inputBinding:
      position: 101
      prefix: -A
  - id: group_b_taxa_file
    type:
      - 'null'
      - File
    doc: file with taxon names (.faa,.gbk,.nucl files) of group B (optional, 
      example -B clade_list_symbiotic.txt)
    inputBinding:
      position: 101
      prefix: -B
  - id: input_matrix
    type: File
    doc: input pangenome matrix .tab (required, made by compare_clusters.pl)
    inputBinding:
      position: 101
      prefix: -m
  - id: list_taxa
    type:
      - 'null'
      - boolean
    doc: list taxa names present in clusters reported in -m matrix (optional, 
      recommended before using -p option)
    inputBinding:
      position: 101
      prefix: -l
  - id: no_cloud
    type:
      - 'null'
      - boolean
    doc: do not compute cloud, matrix does not have cloud clusters (optional, 
      requires -s)
    inputBinding:
      position: 101
      prefix: -n
  - id: plot_pangenes_genome_map
    type:
      - 'null'
      - string
    doc: plot pangenes on the genome map of this group A taxon (optional, 
      example -p 'Escherichia coli K12', requires -g, -A & -B, only works with 
      clusters derived from input files in GenBank format)
    inputBinding:
      position: 101
      prefix: -p
  - id: presence_absence_compliance_a_b
    type:
      - 'null'
      - float
    doc: '% of -A & -B genomes that must comply presence/absence (optional, default=100,
      requires -g)'
    inputBinding:
      position: 101
      prefix: -P
  - id: presence_absence_compliance_b
    type:
      - 'null'
      - float
    doc: '% of -B genomes that must comply presence/absence (optional, requires -g
      & -P, if set -P applies to -A only)'
    inputBinding:
      position: 101
      prefix: -R
  - id: present_in_a_absent_in_b
    type:
      - 'null'
      - boolean
    doc: find genes/clusters present in A which are absent in B (optional, 
      requires -A & -B)
    inputBinding:
      position: 101
      prefix: -g
  - id: produce_intersection_matrix
    type:
      - 'null'
      - boolean
    doc: produce matrix of intersection pangenome clusters (optional, requires 
      -s)
    inputBinding:
      position: 101
      prefix: -x
  - id: report_clusters
    type:
      - 'null'
      - boolean
    doc: report cloud,shell,soft core and core clusters (optional, creates plot 
      if R is installed)
    inputBinding:
      position: 101
      prefix: -s
  - id: skip_low_occupancy_clusters
    type:
      - 'null'
      - int
    doc: skip clusters with occupancy <S (optional, requires -x/-a/-g, example 
      -S 2)
    inputBinding:
      position: 101
      prefix: -S
  - id: use_included_taxa
    type:
      - 'null'
      - File
    doc: use only taxon names included in file (optional, ignores -A,-g,-e)
    inputBinding:
      position: 101
      prefix: -I
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/get_homologues:3.8.1--hdfd78af_0
stdout: get_homologues_parse_pangenome_matrix.pl.out
