cwlVersion: v1.2
class: CommandLineTool
baseCommand: python Periodicity
label: ribominer_Periodicity
doc: "Calculates periodicity of Ribo-seq reads.\n\nTool homepage: https://github.com/xryanglab/RiboMiner"
inputs:
  - id: annot_dir
    type:
      - 'null'
      - Directory
    doc: transcripts annotation directory, generated by prepare_transcripts, a 
      function of RiboCode.
    inputBinding:
      position: 101
      prefix: --annot_dir
  - id: coordinateFile
    type: File
    doc: The file should contain the coordinate of start and stop codon. 
      Generated by OutputTranscriptInfo.py.
    inputBinding:
      position: 101
      prefix: --coordinateFile
  - id: id_type
    type:
      - 'null'
      - string
    doc: define the id type users input. the default is transcript id, if not, 
      will be transformed into transcript id.
    default: transcript_id
    inputBinding:
      position: 101
      prefix: --id-type
  - id: input_bamfile
    type:
      - 'null'
      - File
    doc: Input file(s) in bam format.
    inputBinding:
      position: 101
      prefix: --input
  - id: left_length
    type:
      - 'null'
      - int
    doc: The left range of read length we will consider.
    inputBinding:
      position: 101
      prefix: --left_length
  - id: output_prefix
    type: string
    doc: Prefix of output files.
    inputBinding:
      position: 101
      prefix: --otput_prefix
  - id: right_length
    type:
      - 'null'
      - int
    doc: The right range of read length we will consider.
    inputBinding:
      position: 101
      prefix: --right_length
  - id: select_trans_list
    type:
      - 'null'
      - File
    doc: Selected transcript list used for metagene analysis.This files requires
      the first column must be the transcript ID  with a column name.
    inputBinding:
      position: 101
      prefix: --select_trans_list
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/ribominer:0.2.3.2--pyh5e36f6f_0
stdout: ribominer_Periodicity.out
