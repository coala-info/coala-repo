cwlVersion: v1.2
class: CommandLineTool
baseCommand: sumatra
label: sumatra
doc: "Sumatra is a tool for fast and exact comparison of sequences, designed to handle
  large datasets generated by next-generation sequencing.\n\nTool homepage: https://github.com/sumatrapdfreader/sumatrapdf"
inputs: []
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: biocontainers/sumatra:v1.0.31-2-deb_cv1
stdout: sumatra.out
