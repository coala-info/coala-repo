cwlVersion: v1.2
class: CommandLineTool
baseCommand: mea
label: mea
doc: "The tool accepts dot plot files as generated by RNAfold -p.\nIf a reference
  structure is provided, the predicted (or given) structure is compared to this reference.
  The tool accepts dot-bracket structures with pseudoknots (supporting bracket pairs
  (),{},[],<>,Aa,Bb,...)\nThe result of structure comparison is reported as a line
  of numbers\n\n<TP> <FP> <FN> <TN> <SENS> <PPV> <F1> <MCC>\n\nwhere \n  TP   = #
  true positives\n  FP   = # false positives\n  FN   = # false negatives\n  TN   =
  # true negatives\n  SENS = TP/(TP+FN) 'Sensitivity'\n  PPV  = TP/(TP+FP) 'Positive
  Predictive Value'\n  F1   = PPV*SENS / (PPV+SENS), if PPV+SENS!=0; 0, otherwise\
  \   'F1-score'\n  MCC  = (TP*TN - FP*FN) / sqrt( (TP+FP)*(TP+FN)*(TN+FP)*(TN+FN)
  )\n                                        'Mathews correlation coefficient'\n\n\
  Special rules for prediction evaluation:\n  * Slide rule: tolerate shift of one
  base pair end by one base.\n    This rule directly affects the number of true positives.\n\
  \  * Conflict rule: predicted base pairs are false only if they conflict with\n\
  \    the reference; two base pair conflict if and only if they share one end\n \
  \   This rule directly affects the number of false positives.\n\nTool homepage:
  http://www.bioinf.uni-leipzig.de/Software/mea/"
inputs:
  - id: dotplot_filename
    type: File
    doc: dot plot filename
    inputBinding:
      position: 1
  - id: alpha
    type:
      - 'null'
      - float
    doc: slope of base pair distance penalty
    inputBinding:
      position: 102
      prefix: --alpha
  - id: beta
    type:
      - 'null'
      - float
    doc: turning point of base pair distance penalty
    inputBinding:
      position: 102
      prefix: --beta
  - id: delta
    type:
      - 'null'
      - float
    doc: minimum penalty factor for base pairs
    inputBinding:
      position: 102
      prefix: --delta
  - id: gamma
    type:
      - 'null'
      - float
    doc: base pair weight factor
    inputBinding:
      position: 102
      prefix: --gamma
  - id: no_conflict_rule
    type:
      - 'null'
      - boolean
    doc: 'Use conflict rule [default: use conflict rule]'
    inputBinding:
      position: 102
      prefix: --no-conflict-rule
  - id: no_slide_rule
    type:
      - 'null'
      - boolean
    doc: 'Use slide rule [default: use slide rule]'
    inputBinding:
      position: 102
      prefix: --no-slide-rule
  - id: plot_penalty
    type:
      - 'null'
      - int
    doc: print penalty values between 4 and given value; don't fold
    inputBinding:
      position: 102
      prefix: --plot-penalty
  - id: reference
    type:
      - 'null'
      - string
    doc: Reference structure (dot-bracket)
    inputBinding:
      position: 102
      prefix: --reference
  - id: structure
    type:
      - 'null'
      - string
    doc: Structure (dot-bracket); if given, compare to reference only
    inputBinding:
      position: 102
      prefix: --structure
  - id: verbose
    type:
      - 'null'
      - boolean
    doc: Turn on verbose output
    inputBinding:
      position: 102
      prefix: --verbose
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/mea:0.6.4--h9948957_10
stdout: mea.out
