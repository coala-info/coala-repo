cwlVersion: v1.2
class: CommandLineTool
baseCommand: gemini actionable_mutations
label: gemini_actionable_mutations
doc: "Query the database for actionable mutations.\n\nTool homepage: https://github.com/arq5x/gemini"
inputs:
  - id: db
    type: string
    doc: The name of the database to be queried.
    inputBinding:
      position: 1
outputs:
  - id: stdout
    type: stdout
    doc: Standard output
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/gemini:0.30.2--py27hacb5245_0
stdout: gemini_actionable_mutations.out
