cwlVersion: v1.2
class: CommandLineTool
baseCommand: neat_gen-mut-model
label: neat_gen-mut-model
doc: "Generate mutation model from a pickle or BED file and user input.\n\nTool homepage:
  https://github.com/ncsa/NEAT/"
inputs:
  - id: reference_fa
    type: File
    doc: Reference file for organism in fasta format
    inputBinding:
      position: 1
  - id: mutation_vcf
    type: File
    doc: Mutation file for organism in VCF format
    inputBinding:
      position: 2
  - id: bed_file
    type:
      - 'null'
      - File
    doc: Bed file with regions to use in the model
    inputBinding:
      position: 103
      prefix: --bed
  - id: human_sample
    type:
      - 'null'
      - boolean
    doc: Only use numbered chroms, X, Y, and MT. Omit this flag to include all 
      chroms in reference.
    inputBinding:
      position: 103
      prefix: --human_sample
  - id: outcounts
    type:
      - 'null'
      - File
    doc: Path to trinucleotide counts file for reference (generated by a 
      previous run).If the input file in empty, then instead the output of this 
      run will be saved there. Note, this file will not be used if a bed file is
      also used.
    inputBinding:
      position: 103
      prefix: --outcounts
  - id: overwrite
    type:
      - 'null'
      - boolean
    doc: Set this flag to overwrite existing output.
    inputBinding:
      position: 103
      prefix: --overwrite
  - id: prefix
    type:
      - 'null'
      - string
    doc: Prefix to use to name files
    inputBinding:
      position: 103
      prefix: --prefix
  - id: save_trinuc
    type:
      - 'null'
      - boolean
    doc: Saves trinucleotide counts to a separate file
    inputBinding:
      position: 103
      prefix: --save-trinuc
  - id: show_trinuc
    type:
      - 'null'
      - boolean
    doc: Shows trinucleotide counts, for reference
    inputBinding:
      position: 103
      prefix: --show-trinuc
  - id: skip_common
    type:
      - 'null'
      - boolean
    doc: Includes a list of common variants, if you want to visualize common 
      variants with plot_mut_model.py.
    inputBinding:
      position: 103
      prefix: --skip_common
outputs:
  - id: output_dir
    type:
      - 'null'
      - Directory
    doc: Path to the output directory. Will create if not present.
    outputBinding:
      glob: $(inputs.output_dir)
hints:
  - class: DockerRequirement
    dockerPull: quay.io/biocontainers/neat:4.3.5--pyhdfd78af_0
